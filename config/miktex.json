{
  "xelatex_command": "xelatex",
  "version_arg": "--version",
  "compile_flags": [
    "-interaction=nonstopmode",
    "-halt-on-error"
  ],
  "runs": 2,
  "output_pdf_name": "main.pdf",
  "distribution": "MiKTeX",
  "minimum_major_version": 0,
  "env": {
    "xelatex_command": "VIDEO_FULL_XELATEX_COMMAND"
  }
}
